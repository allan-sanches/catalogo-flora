# Variáveis do Keystatic em produção (storage GitHub).
# Em desenvolvimento (npm run dev) NÃO precisa de nada disso: usa storage local.
#
# Estes valores são gerados automaticamente quando você acessa /keystatic no site
# publicado e clica em "Connect to GitHub" (cria a GitHub App da Flora Mattos).
# Depois, copie-os para as Environment Variables do projeto na Vercel.

# Chave aleatória para assinar a sessão do Keystatic (gere uma string longa)
KEYSTATIC_SECRET=

# Credenciais da GitHub App criada pelo onboarding do Keystatic
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=

# Slug (nome) da GitHub App — exposto ao cliente para o link de instalação
NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
